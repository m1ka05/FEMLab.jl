{
  "name": "FEMLab.jl Codespace",

  "image": "julia:1.12-bookworm",

  "containerEnv": {
    "JULIA_PROJECT": "${containerWorkspaceFolder}",
    "JULIA_NUM_THREADS": "auto"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "julialang.language-julia"
      ],
      "settings": {
        "julia.environmentPath": "${containerWorkspaceFolder}",
        "julia.executablePath": "/usr/local/julia/bin/julia",
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "JULIA_PROJECT": "${containerWorkspaceFolder}",
          "JULIA_NUM_THREADS": "auto"
        }
      }
    }
  },

  "updateContentCommand": "julia --startup-file=no --project=${containerWorkspaceFolder} -e 'using Pkg; Pkg.instantiate(); Pkg.precompile(); using FEMLab; println(\"FEMLab prebuild ready.\")'",
  "postAttachCommand": "echo 'FEMLab.jl Codespace ready. Julia project: ${containerWorkspaceFolder}'"
}